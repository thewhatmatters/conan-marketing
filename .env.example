# Vercel KV (waitlist email storage) — Upstash Redis under the hood.
# Reuse the SAME store as conan-license (zero new infra). Get the values from
# the conan-license Vercel project → Storage → KV → ".env.local" tab, or run
# `vercel env pull` inside conan-license and copy these two lines here.
#
# Until these are set, /api/waitlist still accepts signups but does NOT store
# them (it logs a warning). Once set, emails persist to the `waitlist:emails`
# set. Add the same two vars to this project's Vercel env when it's connected.
KV_REST_API_URL=
KV_REST_API_TOKEN=
