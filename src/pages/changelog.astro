---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { releases, releaseUrl, type Release } from "../data/releases.ts";

// Public release timeline. A vertical ember rail with a node per version,
// newest first; the latest carries a "Latest" badge. Data lives in
// ../data/releases.ts — add a new entry at the top when you cut a release.

const longDate = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });

// Node accent + label per release kind. Warm palette only (ember / gold).
const KIND: Record<
  NonNullable<Release["kind"]>,
  { label: string; dot: string; pill: string }
> = {
  launch: {
    label: "Launch",
    dot: "bg-ember ring-ember/30",
    pill: "bg-ember/15 text-ember",
  },
  feature: {
    label: "Feature",
    dot: "bg-ember ring-ember/25",
    pill: "bg-ember/12 text-ember",
  },
  fix: {
    label: "Fix",
    dot: "bg-gold ring-gold/25",
    pill: "bg-gold/12 text-gold",
  },
};

// JSON-LD: each release as a SoftwareApplication version helps AI engines and
// rich results answer "what changed in Conan / latest version" cleanly.
const changelogLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Conan release history",
  itemListElement: releases.map((r, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "SoftwareApplication",
      name: `Conan ${r.version}`,
      softwareVersion: r.version,
      datePublished: r.date,
      applicationCategory: "DeveloperApplication",
      operatingSystem: "macOS 13 or later (Apple silicon)",
      url: releaseUrl(r.version),
      releaseNotes: r.summary,
    },
  })),
};
---

<Layout
  title="Changelog"
  description="Every Conan release, newest first — what shipped and when. A native macOS HUD for Claude Code."
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(changelogLd)}
  />
  <Header />

  <main class="shell pb-24 pt-28 lg:pb-32 lg:pt-36">
    <!-- Page head -->
    <header class="max-w-[68ch]">
      <p
        class="mb-4 flex items-center gap-3 text-[11px] uppercase tracking-[0.25em] text-muted-foreground"
      >
        <span class="h-px w-6 bg-gold/70"></span>
        Releases
      </p>
      <h1
        class="font-display text-[clamp(1.9rem,4vw,2.75rem)] font-bold tracking-tight text-foreground"
      >
        Changelog
      </h1>
      <p class="mt-3 text-[0.98rem] leading-relaxed text-muted-foreground">
        Every Conan release, newest first. The app updates itself — these are
        the notes for what shipped and when.
      </p>
    </header>

    <!-- Timeline -->
    <ol class="relative mt-14 max-w-[70ch] border-l border-border pl-8 lg:pl-10">
      {
        releases.map((r, i) => {
          const kind = KIND[r.kind ?? "feature"];
          const latest = i === 0;
          return (
            <li class="relative pb-14 last:pb-0">
              {/* Node on the rail */}
              <span
                aria-hidden="true"
                class:list={[
                  "absolute -left-[calc(2rem+5px)] top-1.5 h-2.5 w-2.5 rounded-full ring-4 lg:-left-[calc(2.5rem+5px)]",
                  kind.dot,
                ]}
              />

              {/* Version · date · kind */}
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2">
                <a
                  href={releaseUrl(r.version)}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-display text-lg font-bold tracking-tight text-foreground transition-colors hover:text-ember"
                >
                  v{r.version}
                </a>
                {latest && (
                  <span class="rounded-full bg-ember px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-primary-foreground">
                    Latest
                  </span>
                )}
                <span
                  class:list={[
                    "rounded-full px-2 py-0.5 text-[10px] font-medium uppercase tracking-wide",
                    kind.pill,
                  ]}
                >
                  {kind.label}
                </span>
                <span class="text-xs text-muted-foreground">
                  {longDate(r.date)}
                </span>
              </div>

              {/* Title + summary */}
              <h2 class="mt-3 text-base font-semibold text-foreground">
                {r.title}
              </h2>
              <p class="mt-1.5 text-[0.95rem] leading-relaxed text-muted-foreground">
                {r.summary}
              </p>

              {/* Highlights */}
              <ul class="mt-3 space-y-1.5">
                {r.highlights.map((h) => (
                  <li class="relative pl-5 text-[0.9rem] leading-relaxed text-muted-foreground">
                    <span
                      aria-hidden="true"
                      class="absolute left-0 top-[0.6em] h-1 w-1 rounded-full bg-gold/70"
                    />
                    {h}
                  </li>
                ))}
              </ul>
            </li>
          );
        })
      }
    </ol>

    <!-- Foot note -->
    <p class="mt-4 max-w-[70ch] border-l border-border pl-8 text-xs text-muted-foreground lg:pl-10">
      Full notes for every build live on{" "}
      <a
        href="https://github.com/thewhatmatters/conan/releases"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gold underline-offset-[3px] hover:underline"
      >
        GitHub Releases
      </a>.
    </p>
  </main>

  <Footer />
</Layout>
