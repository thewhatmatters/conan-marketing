---
// Sticky site header, COMPUTE-style.
//   • At top: full-bleed, transparent, sits flush over the hero.
//   • On scroll: collapses into a floating capsule — insets from the edges,
//     narrows, rounds its corners, and gains a translucent blurred bg + border.
// No island: a tiny passive scroll listener toggles `data-scrolled`; the rest
// is CSS transitions driven off the group-data variant.
// Absolute "/#section" hrefs so the nav works from any page (incl. /terms,
// /privacy) — on the homepage they still scroll same-document; off it they
// navigate home and scroll. Route-only links (Legal) stay path-based.
const navLinks = [
  { label: "Features", href: "/#features" },
  { label: "Changelog", href: "/changelog" },
  { label: "FAQ", href: "/#faq" },
  // href stays the click target (scroll to the form); spy highlights "Get
  // notified" across the whole closing section (footer) so it stays lit to the
  // page bottom. Restored after the download-CTA swap dropped it.
  { label: "Get notified", href: "/#waitlist", spy: "#closing" },
];

// The Mac download — latest GitHub Release .dmg (Apple silicon). The "/latest/
// download/" path always resolves to the newest release asset, so this never
// needs bumping per version.
const downloadHref =
  "https://github.com/thewhatmatters/conan/releases/latest/download/Conan_aarch64.dmg";
---

<header
  id="site-header"
  data-scrolled="false"
  class="group fixed inset-x-0 top-0 z-50 px-0 pt-0 transition-[padding] duration-300 ease-out data-[scrolled=true]:px-3 data-[scrolled=true]:pt-3"
>
  <nav
    style="--nav-hug: 520px"
    class="relative isolate mx-auto flex max-w-[1280px] items-center gap-4 whitespace-nowrap rounded-none border border-transparent bg-transparent px-6 py-5 shadow-none transition-all duration-300 ease-out lg:px-12 group-data-[scrolled=true]:max-w-[var(--nav-hug)] group-data-[scrolled=true]:gap-11 group-data-[scrolled=true]:rounded-full group-data-[scrolled=true]:border-border group-data-[scrolled=true]:bg-background/70 group-data-[scrolled=true]:px-2.5 group-data-[scrolled=true]:py-2.5 group-data-[scrolled=true]:shadow-lg group-data-[scrolled=true]:backdrop-blur-xl"
  >
    <!-- Lightning flash — plays once when the bar compacts. NOT clipped: the
         bolt overflows the capsule, striking above and below the bar.
         Screen-blended so only the gold shows; sits behind the content
         (-z-10 within the nav's stacking context). -->
    <div
      id="nav-lightning"
      aria-hidden="true"
      class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[240px] w-[320px] -translate-x-1/2 -translate-y-1/2 opacity-0 mix-blend-screen"
    >
    </div>
    <!-- Logo (in a flex-1 wrapper so the links sit centred at the top; the
         wrapper collapses to the logo width when the bar hugs). The asset is a
         pre-composed circular badge (warm coin + ember ring), so no extra
         ring/bg here. -->
    <div class="flex flex-1 items-center">
      <a
        href="/"
        aria-label="Conan"
        class="flex shrink-0 transition-opacity hover:opacity-80"
      >
        <img
          src="/logo.png"
          alt="Conan"
          width="32"
          height="32"
          class="h-8 w-8 rounded-full object-cover"
        />
      </a>
    </div>

    <!-- Links — inline in both states (no position switch → smooth compaction).
         Centred at the top by the equal flex-1 sides. -->
    <ul
      class="relative isolate hidden shrink-0 items-center gap-8 md:flex group-data-[scrolled=true]:gap-6"
    >
      <!-- Shared highlight: one pill that slides + resizes between active items
           (driven by the scroll-spy in the script). Hidden when none active. -->
      <span
        id="nav-pill"
        aria-hidden="true"
        class="pointer-events-none absolute inset-y-0 left-0 z-0 w-0 rounded-full bg-foreground/10 opacity-0"
        style="transition: transform 400ms cubic-bezier(0.16,1,0.3,1), width 400ms cubic-bezier(0.16,1,0.3,1), opacity 250ms ease-out;"
      >
      </span>
      {
        navLinks.map((l) => (
          <li>
            <a
              href={l.href}
              data-spy={l.spy}
              class="relative z-10 -mx-4 inline-flex items-center px-4 py-2 text-sm text-muted-foreground transition-colors duration-300 ease-out hover:text-foreground data-[active=true]:text-foreground"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Right actions (flex-1 mirrors the wordmark wrapper to keep links centred). -->
    <div class="flex flex-1 items-center justify-end gap-3">
      <a
        href={downloadHref}
        data-dl="header"
        class="inline-flex items-center rounded-full bg-primary px-4 py-2 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90"
      >
        Download for Mac
      </a>
    </div>
  </nav>
</header>

<script>
  import lottie from "lottie-web/build/player/lottie_light";

  const header = document.getElementById("site-header");
  const mount = document.getElementById("nav-lightning");
  const reduceMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

  // Lightning flash — plays on scroll-state transitions (compact/expand, both
  // directions) and on nav-link clicks. NEVER on load: the mount is hidden at
  // rest (opacity 0, so the static first frame can't show) and only revealed
  // while playing. Skipped entirely under reduced motion.
  let bolt: ReturnType<typeof lottie.loadAnimation> | null = null;
  if (mount && !reduceMotion) {
    bolt = lottie.loadAnimation({
      container: mount,
      renderer: "svg",
      loop: false,
      autoplay: false,
      path: "/animations/lightning.json",
      rendererSettings: { preserveAspectRatio: "xMidYMid meet" },
    });
    bolt.setSpeed(1.4);
    bolt.addEventListener("complete", () => {
      if (mount) mount.style.opacity = "0";
    });
  }

  const playBolt = () => {
    if (!bolt || !mount) return;
    mount.style.opacity = "0.9";
    bolt.goToAndStop(0, true);
    bolt.play();
  };

  // Sync the compacted state on load WITHOUT playing (avoids the load flash).
  let scrolled = window.scrollY > 8;
  header?.setAttribute("data-scrolled", String(scrolled));

  // Measure the compacted pill's content width once (after fonts load) into
  // --nav-hug, so max-width can animate full -> exact content width smoothly.
  // (Animating to `width: max-content` directly isn't transitionable; max-w:0
  // just collapses the box. A measured px target gives a clean morph.)
  const nav = header?.querySelector("nav") as HTMLElement | null;
  const navUl = nav?.querySelector("ul") as HTMLElement | null;
  const pill = document.getElementById("nav-pill");
  // Derive the "#section" hash from a link's href ("/#features" → "#features";
  // route-only links like "Legal" → /terms have none). The spy uses hash links
  // only, so querySelector never chokes on a path, and on pages without those
  // sections (the legal pages) it simply finds nothing and no-ops.
  const hashOf = (a: HTMLAnchorElement) => {
    const href = a.getAttribute("href") || "";
    const i = href.indexOf("#");
    return i >= 0 ? href.slice(i) : null;
  };
  const spyLinks = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('#site-header ul a[href*="#"]'),
  );
  let activeLink: HTMLAnchorElement | null = null;

  // Slide the shared highlight pill onto the active link (or hide it).
  const movePill = () => {
    if (!pill || !navUl) return;
    if (!activeLink) {
      pill.style.opacity = "0";
      return;
    }
    const u = navUl.getBoundingClientRect();
    const r = activeLink.getBoundingClientRect();
    pill.style.width = `${Math.round(r.width)}px`;
    pill.style.transform = `translateX(${Math.round(r.left - u.left)}px)`;
    pill.style.opacity = "1";
  };

  const measureHug = () => {
    if (!nav || !header) return;
    const s = nav.style;
    const prev = { width: s.width, maxWidth: s.maxWidth, transition: s.transition };
    const was = header.getAttribute("data-scrolled");
    s.transition = "none";
    header.setAttribute("data-scrolled", "true");
    s.maxWidth = "none";
    s.width = "max-content";
    const hug = Math.ceil(nav.getBoundingClientRect().width) + 1;
    s.width = prev.width;
    s.maxWidth = prev.maxWidth;
    header.setAttribute("data-scrolled", was || "false");
    void nav.offsetWidth; // commit the restore before re-enabling transitions
    s.transition = prev.transition;
    nav.style.setProperty("--nav-hug", `${hug}px`);
  };
  if (nav) {
    (document.fonts?.ready ?? Promise.resolve()).then(() => {
      measureHug();
      movePill();
    });
    let rt = 0;
    window.addEventListener("resize", () => {
      clearTimeout(rt);
      rt = window.setTimeout(() => {
        measureHug();
        movePill();
      }, 150);
    });
  }

  const onScroll = () => {
    const now = window.scrollY > 8;
    if (now === scrolled) return;
    scrolled = now;
    header?.setAttribute("data-scrolled", String(now));
    playBolt(); // fire on both directions (scroll down to compact, up to expand)
  };
  window.addEventListener("scroll", onScroll, { passive: true });

  // Also flash on nav-link clicks.
  document
    .querySelectorAll("#site-header ul a")
    .forEach((a) => a.addEventListener("click", () => playBolt()));

  // Scroll-spy: active = the LAST target whose top has crossed the viewport
  // centre line (top-passed-centre keeps each section active across its whole
  // span and holds the final one lit to the page bottom). Each link's
  // active-region element is its `data-spy` override (e.g. "Get notified" →
  // #closing, the whole closing section) or its href hash. On pages without a
  // target (the legal pages for hash links) it simply finds nothing and no-ops.
  const targetOf = (a: HTMLAnchorElement) => {
    const sel = a.dataset.spy || hashOf(a);
    return sel ? document.querySelector(sel) : null;
  };
  const targets = spyLinks
    .map((a) => ({ link: a, el: targetOf(a) }))
    .filter((t): t is { link: HTMLAnchorElement; el: Element } => !!t.el);
  const setActiveLink = (link: HTMLAnchorElement | null) => {
    activeLink = link;
    spyLinks.forEach((a) => a.setAttribute("data-active", String(a === link)));
    movePill();
  };
  if (targets.length) {
    const updateActive = () => {
      const line = window.scrollY + window.innerHeight * 0.5;
      let active: HTMLAnchorElement | null = null;
      let best = -Infinity;
      for (const t of targets) {
        const top = t.el.getBoundingClientRect().top + window.scrollY;
        if (top <= line && top > best) {
          best = top;
          active = t.link;
        }
      }
      setActiveLink(active);
    };
    updateActive();
    window.addEventListener("scroll", updateActive, { passive: true });
    window.addEventListener("resize", updateActive);
    spyLinks.forEach((a) =>
      a.addEventListener("click", () => setActiveLink(a)),
    );
  }
</script>
