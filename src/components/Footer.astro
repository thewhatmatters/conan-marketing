---
// Footer: dark "ink & fire" ground with a subtle ember glow at the top edge, a
// compact brand mark + trust strip, the bottom-tethered barbarian art, and a
// giant CONAN wordmark behind it. Nav links were removed (they live in the
// header; Terms/Privacy live in the FAQ).
---

<footer id="closing" class="footer relative isolate overflow-hidden bg-background">
  <!-- Giant CONAN wordmark — behind the figure, anchored to the footer's bottom.
       Drifts up slightly as the section scrolls through the viewport (parallax,
       set by the script below; static under reduced-motion). -->
  <div
    id="conan-parallax"
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 z-0 overflow-hidden will-change-transform"
  >
    <span
      class="block translate-y-[0.16em] select-none bg-gradient-to-b from-ember/60 via-ember/30 to-transparent bg-clip-text text-center font-display text-[clamp(4.5rem,23vw,22rem)] font-bold leading-[0.8] tracking-tight text-transparent"
    >
      CONAN
    </span>
  </div>

  <!-- Bottom-tethered barbarian — kept in NORMAL FLOW so it sets the footer's
       height (the figure is the only content). Sits above the wordmark. Uses the
       processed asset: cropped to drop the editor's baked transparency
       checkerboard in the base dust + tight-trimmed margins + resized from the
       9MB source (conan-footer.png) to a 144KB webp. The coin hoard is now the
       image's bottom edge, so the figure seats flush to the footer bottom. -->
  <div class="relative z-[5] flex justify-center px-6 pt-14 lg:pt-16">
    <img
      src="/footer/conan-footer-web.webp"
      alt=""
      aria-hidden="true"
      class="pointer-events-none block w-[820px] max-w-full select-none object-contain"
    />
  </div>

  <!-- Bottom blend: a gradient overlay ramping to the page background so the
       figure + wordmark dissolve into the bottom edge — the hero-loop technique.
       Sits above both (z-6). Tune: height + gradient stops. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 z-[6] h-80"
    style="background: linear-gradient(to bottom, transparent, rgba(12,10,9,0.45) 58%, #0c0a09 92%);"
  >
  </div>
</footer>

<script>
  // Parallax: the CONAN wordmark drifts UP as the closing section travels through
  // the viewport. rAF-throttled scroll → transform on the wrapper (cheap, GPU).
  // Skipped under reduced-motion (stays at its resting position).
  const wrap = document.getElementById("conan-parallax");
  const section = document.getElementById("closing");
  if (
    wrap &&
    section &&
    !matchMedia("(prefers-reduced-motion: reduce)").matches
  ) {
    const MAX = 90; // px of upward drift across the full scroll-through
    let ticking = false;
    const update = () => {
      ticking = false;
      const rect = section.getBoundingClientRect();
      const vh = window.innerHeight;
      // 0 when the section's top is at the viewport bottom → 1 once it's fully
      // scrolled past the top.
      const progress = Math.min(
        1,
        Math.max(0, (vh - rect.top) / (vh + rect.height)),
      );
      wrap.style.transform = `translateY(${-progress * MAX}px)`;
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    update();
  }
</script>
