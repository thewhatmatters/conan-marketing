---
// Fire-finale footer: ember flames lick up from the top edge, fuller link
// columns + social + trust strip sit on the dark ground, and a giant CONAN
// wordmark bleeds off the bottom. Palette intentionally inverted from the
// bright-orange reference — dark ground, ember/oxblood flames — to stay on the
// site's "ink & fire" system. Hand-built flame SVG (swap for a designed asset
// later if we want more flourish).
const columns = [
  {
    title: "Product",
    links: [
      { label: "Features", href: "#features" },
      { label: "Pricing", href: "#pricing" },
      { label: "FAQ", href: "#faq" },
      { label: "Download for Mac", href: "#download" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "WhatMatters", href: "https://whatmatters.so" },
      { label: "Terms", href: "#" },
      { label: "Privacy", href: "#" },
    ],
  },
  {
    title: "Other platforms",
    links: [{ label: "Windows & Linux? Notify me →", href: "#download" }],
  },
];

const githubHref = "https://github.com/";

// Flame tongues as teardrop paths (pointed tip, rounded base) — far more
// fire-like than a single wavy edge. Two rows: oxblood behind (taller), ember
// in front. Tuned by hand; swap for a designed SVG later if we want more polish.
const flame = (cx: number, w: number, tip: number, base = 200) => {
  const h = base - tip;
  const r = (n: number) => Math.round(n);
  return `M${cx},${base} C${r(cx - w)},${r(base - h * 0.15)} ${r(cx - w * 0.5)},${r(tip + h * 0.42)} ${cx},${tip} C${r(cx + w * 0.5)},${r(tip + h * 0.42)} ${r(cx + w)},${r(base - h * 0.15)} ${cx},${base} Z`;
};
// [centerX, halfWidth, tipY]
const backFlames = [
  [120, 95, 18], [340, 100, 44], [560, 95, 12], [780, 105, 38],
  [1000, 100, 16], [1230, 98, 34], [1420, 88, 54],
];
const frontFlames = [
  [55, 68, 72], [165, 54, 28], [275, 78, 98], [400, 60, 16], [510, 72, 88],
  [620, 54, 46], [742, 82, 104], [862, 60, 24], [972, 74, 82], [1092, 58, 38],
  [1202, 80, 98], [1322, 62, 28], [1412, 64, 74],
];
---

<footer class="footer relative isolate overflow-hidden bg-background">
  <!-- Ember glow rising behind the flames. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-72"
    style="background: radial-gradient(70% 100% at 50% 0%, rgba(217,119,6,0.22), rgba(127,29,29,0.12) 45%, transparent 75%);"
  >
  </div>

  <!-- Flame top edge (two-tone for depth). Stretches full-width; aria-hidden. -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 -z-10">
    <svg
      class="h-28 w-full lg:h-40"
      viewBox="0 0 1440 200"
      preserveAspectRatio="none"
      fill="none"
    >
      <!-- solid base so the tongues share a fire-line, not float -->
      <rect x="0" y="188" width="1440" height="12" fill="var(--ember)"></rect>
      <!-- back layer: oxblood, taller -->
      {
        backFlames.map(([cx, w, tip]) => (
          <path d={flame(cx, w, tip)} fill="var(--oxblood)" opacity="0.6" />
        ))
      }
      <!-- front layer: ember, with a soft glow -->
      <g style="filter: drop-shadow(0 -6px 18px rgba(217,119,6,0.45));">
        {frontFlames.map(([cx, w, tip]) => <path d={flame(cx, w, tip)} fill="var(--ember)" />)}
      </g>
    </svg>
  </div>

  <!-- Columns -->
  <div class="shell relative z-10 pt-40 lg:pt-56">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4 lg:gap-12">
      <!-- Brand + social -->
      <div class="col-span-2 flex flex-col gap-4 md:col-span-1">
        <a href="/" class="flex items-baseline gap-1.5">
          <span class="text-lg font-semibold uppercase tracking-[0.2em] text-foreground"
            >Conan</span
          >
          <span class="text-xs text-muted-foreground">.sh</span>
        </a>
        <p class="max-w-[18ch] text-xs leading-relaxed text-muted-foreground">
          A barbarian misses nothing.
        </p>
        <div class="mt-1 flex items-center gap-3">
          <a
            href={githubHref}
            aria-label="Conan on GitHub"
            class="text-muted-foreground transition-colors hover:text-gold"
          >
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
              <path
                d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.1 3.29 9.42 7.86 10.95.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.53-1.35-1.3-1.71-1.3-1.71-1.06-.73.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.79 2.73 1.27 3.4.97.1-.76.41-1.27.74-1.56-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.28 1.19-3.08-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.8 1.19 1.83 1.19 3.08 0 4.41-2.69 5.38-5.25 5.67.42.36.8 1.08.8 2.18v3.23c0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.02C23.5 5.74 18.27.5 12 .5Z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Link columns -->
      {
        columns.map((col) => (
          <nav class="flex flex-col gap-3">
            <p class="text-[11px] uppercase tracking-[0.2em] text-gold">
              {col.title}
            </p>
            {col.links.map((l) => (
              <a
                href={l.href}
                class="text-sm text-muted-foreground transition-colors hover:text-gold"
              >
                {l.label}
              </a>
            ))}
          </nav>
        ))
      }
    </div>

    <!-- Trust strip -->
    <div class="mt-16 border-t border-border/40 pt-6">
      <p class="text-[11px] leading-relaxed text-muted-foreground">
        © 2026 WhatMatters · Not affiliated with Anthropic · Not affiliated with
        Conan Properties Int'l · Payments by Polar (Merchant of Record)
      </p>
    </div>
  </div>

  <!-- Giant wordmark, bleeding off the bottom (decorative). -->
  <div class="relative z-0 mt-12 overflow-hidden lg:mt-16" aria-hidden="true">
    <span
      class="block translate-y-[0.16em] select-none bg-gradient-to-b from-ember/35 via-ember/15 to-transparent bg-clip-text text-center font-display text-[clamp(4.5rem,23vw,22rem)] font-bold leading-[0.8] tracking-tight text-transparent"
    >
      CONAN
    </span>
  </div>
</footer>
