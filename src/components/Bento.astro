---
// Benefits bento — an asymmetric comic-panel grid (5 tiles). Heavy ink gutters,
// numbered panels, gold accents, and hand-built "live" product visuals (no
// screenshots yet). Reveals on scroll via a tiny IntersectionObserver (.is-in).
const skills = ["filesystem", "git", "playwright", "memory", "fetch", "sqlite"];
---

<section id="features" class="relative py-24 lg:py-32">
  <div class="shell">
    <!-- Section intro -->
    <div class="mb-12 max-w-2xl">
      <p class="mb-4 flex items-center gap-3 text-xs uppercase tracking-[0.25em] text-muted-foreground">
        <span class="h-px w-8 bg-gold/70"></span>
        What it watches
      </p>
      <h2 class="font-display text-[clamp(1.75rem,4vw,3.25rem)] font-bold leading-[0.98] tracking-tight text-foreground">
        Nothing escapes the watch.
      </h2>
    </div>

    <!-- Comic-panel grid -->
    <div
      class="bento grid grid-cols-1 gap-4 lg:grid-cols-12 lg:auto-rows-[minmax(232px,1fr)] lg:gap-5"
    >
      <!-- 01 — Timeline (LARGE) -->
      <article
        class="bento-tile group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card p-6 transition duration-300 hover:-translate-y-1 hover:border-ember/40 hover:shadow-[0_0_50px_-14px] hover:shadow-ember/40 lg:col-span-7 lg:row-span-2"
        style="--d: 0ms"
      >
        <div class="flex-1">
          <div class="space-y-2.5">
            {
              [
                { t: "14:02:51", a: "edited", f: "src/radio/RadioBar.tsx" },
                { t: "14:02:53", a: "ran", f: "npm run typecheck" },
                { t: "14:03:07", a: "read", f: "ui/src/index.css" },
                { t: "14:03:14", a: "wrote", f: "Bento.astro" },
                { t: "14:03:20", a: "called", f: "mcp · playwright" },
              ].map((row, i) => (
                <div
                  class="tl-row flex items-center gap-3 rounded-lg border border-border/60 bg-background/40 px-3 py-2"
                  style={`--d: ${220 + i * 90}ms`}
                >
                  <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-ember shadow-[0_0_8px] shadow-ember/80" />
                  <span class="text-[11px] text-muted-foreground">{row.t}</span>
                  <span class="text-[11px] text-gold">{row.a}</span>
                  <span class="truncate text-[11px] text-foreground/80">{row.f}</span>
                </div>
              ))
            }
          </div>
        </div>
        <div class="mt-6">
          <p class="mb-1.5 text-[11px] uppercase tracking-[0.2em] text-gold">
            01 · Timeline
          </p>
          <h3 class="mb-2 text-xl font-semibold text-foreground">
            Every deed, driven before you
          </h3>
          <p class="max-w-md text-sm leading-relaxed text-muted-foreground">
            Each command, edit, and tool call streams onto a living timeline —
            the whole campaign, as it happens.
          </p>
        </div>
      </article>

      <!-- 02 — Context + Usage -->
      <article
        class="bento-tile group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card p-6 transition duration-300 hover:-translate-y-1 hover:border-ember/40 hover:shadow-[0_0_50px_-14px] hover:shadow-ember/40 lg:col-span-5"
        style="--d: 90ms"
      >
        <div class="flex flex-1 items-center gap-5">
          <div class="relative h-24 w-24 shrink-0">
            <svg viewBox="0 0 100 100" class="h-full w-full -rotate-90">
              <circle cx="50" cy="50" r="42" fill="none" stroke="var(--border)" stroke-width="7"></circle>
              <circle
                class="ring-fg"
                cx="50"
                cy="50"
                r="42"
                fill="none"
                stroke="var(--ember)"
                stroke-width="7"
                stroke-linecap="round"
                stroke-dasharray="263.9"
                stroke-dashoffset="84.5"></circle>
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="font-display text-2xl font-bold text-foreground">68%</span>
            </div>
          </div>
          <div class="text-xs leading-relaxed text-muted-foreground">
            <div class="text-foreground/80">47.2k <span class="text-muted-foreground">/ 200k tokens</span></div>
            <div class="mt-1 text-gold">$0.41 this session</div>
          </div>
        </div>
        <div class="mt-6">
          <p class="mb-1.5 text-[11px] uppercase tracking-[0.2em] text-gold">
            02 · Context
          </p>
          <h3 class="mb-2 text-xl font-semibold text-foreground">
            Know the cost of every move
          </h3>
          <p class="text-sm leading-relaxed text-muted-foreground">
            Watch the context window fill and tokens burn — in real time.
          </p>
        </div>
      </article>

      <!-- 03 — Pulse -->
      <article
        class="bento-tile group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card p-6 transition duration-300 hover:-translate-y-1 hover:border-ember/40 hover:shadow-[0_0_50px_-14px] hover:shadow-ember/40 lg:col-span-5"
        style="--d: 180ms"
      >
        <div class="flex flex-1 items-center">
          <svg viewBox="0 0 320 80" preserveAspectRatio="none" class="h-16 w-full">
            <polyline
              points="0,40 56,40 78,40 90,16 104,64 118,40 168,40 188,40 202,10 218,70 234,40 320,40"
              fill="none"
              stroke="var(--border)"
              stroke-width="2"></polyline>
            <polyline
              class="pulse-blip"
              points="0,40 56,40 78,40 90,16 104,64 118,40 168,40 188,40 202,10 218,70 234,40 320,40"
              fill="none"
              stroke="var(--ember)"
              stroke-width="2.5"
              stroke-linecap="round"
              style="filter: drop-shadow(0 0 5px var(--ember));"></polyline>
          </svg>
        </div>
        <div class="mt-6">
          <p class="mb-1.5 text-[11px] uppercase tracking-[0.2em] text-gold">
            03 · Pulse
          </p>
          <h3 class="mb-2 text-xl font-semibold text-foreground">
            Feel the session's heartbeat
          </h3>
          <p class="text-sm leading-relaxed text-muted-foreground">
            A live pulse of activity — spikes when Claude works, calm when it waits.
          </p>
        </div>
      </article>

      <!-- 04 — Skills + MCP -->
      <article
        class="bento-tile group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card p-6 transition duration-300 hover:-translate-y-1 hover:border-ember/40 hover:shadow-[0_0_50px_-14px] hover:shadow-ember/40 lg:col-span-8"
        style="--d: 120ms"
      >
        <div class="flex flex-1 flex-wrap content-start gap-2">
          {
            skills.map((s) => (
              <span class="rounded-full border border-border bg-background/40 px-3 py-1.5 text-xs text-foreground/80">
                {s}
              </span>
            ))
          }
          <span class="rounded-full border border-gold/40 bg-gold/10 px-3 py-1.5 text-xs text-gold">
            + 9 more
          </span>
        </div>
        <div class="mt-6">
          <p class="mb-1.5 text-[11px] uppercase tracking-[0.2em] text-gold">
            04 · Skills &amp; MCP
          </p>
          <h3 class="mb-2 text-xl font-semibold text-foreground">
            See every tool it wields
          </h3>
          <p class="max-w-md text-sm leading-relaxed text-muted-foreground">
            Skills and MCP servers, surfaced and observable — know exactly what's in play.
          </p>
        </div>
      </article>

      <!-- 05 — Radio (SMALL / wink) -->
      <article
        class="bento-tile group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card p-6 transition duration-300 hover:-translate-y-1 hover:border-ember/40 hover:shadow-[0_0_50px_-14px] hover:shadow-ember/40 lg:col-span-4"
        style="--d: 210ms"
      >
        <div class="flex flex-1 items-center gap-3">
          <div class="flex h-12 items-end gap-1">
            {
              [0, 1, 2, 3, 4].map((i) => (
                <span
                  class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-gold to-ember"
                  style={`height: 100%; animation-delay: ${i * 0.14}s`}
                />
              ))
            }
          </div>
          <span class="text-[11px] text-muted-foreground">lo-fi beats to raid to</span>
        </div>
        <div class="mt-6">
          <p class="mb-1.5 text-[11px] uppercase tracking-[0.2em] text-gold">
            05 · Radio
          </p>
          <h3 class="mb-2 text-xl font-semibold text-foreground">Lo-fi, built in</h3>
          <p class="text-sm leading-relaxed text-muted-foreground">
            Claude Radio hums while you work.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

<script>
  const bento = document.querySelector(".bento");
  if (bento) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-in");
            obs.unobserve(e.target);
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(bento);
  }
</script>
