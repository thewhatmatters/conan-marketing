---
import HeroWord from "./HeroWord.tsx";

// CTAs. Stubs for now — downloadHref scrolls to the CTA band (id="download");
// swap for the latest GitHub Release .dmg once published.
const downloadHref = "#download";
const githubHref = "https://github.com/";
---

<section
  class="relative isolate flex min-h-screen flex-col overflow-hidden pb-0 pt-32 lg:pt-40"
>
  <!-- Background loop. `autoplay muted playsinline loop` is the canonical combo
       for reliable INLINE autoplay on iOS/Safari (a JS-only .play() is flaky
       there and blocked entirely in Low Power Mode). The script below honours
       prefers-reduced-motion by pausing to the poster frame. Poster is a real
       still from the clip, so the hero is never blank if playback is blocked.
       Sits furthest back (-z-20); the warm gradient layers tint it and keep the
       headline readable. -->
  <video
    id="hero-video"
    class="pointer-events-none absolute inset-0 -z-20 h-full w-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster="/hero/hero-poster.jpg"
    aria-hidden="true"
  >
    <source src="/video/conan-battle-dark.mp4" type="video/mp4" />
  </video>

  <!-- Radial darken/fade over the loop: subdues the footage and adds depth —
       lighter toward the figure (right), darker at the edges. Sits above the
       video (-z-15) but below the content. `hero-veil` keeps it transparent on
       load (clean video) then fades it in after the headline rises. -->
  <div
    aria-hidden="true"
    class="hero-veil pointer-events-none absolute inset-0 -z-[15]"
    style="background: radial-gradient(90% 85% at 62% 42%, rgba(12,10,9,0.05), rgba(12,10,9,0.38) 100%);"
  >
  </div>

  <!-- Edge vignette. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(120% 95% at 50% 35%, transparent 52%, rgba(0,0,0,0.65) 100%);"
  >
  </div>
  <!-- Faint warm grid (12 × 8). -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.06]"
    style="background-image:
      linear-gradient(to right, var(--bone) 1px, transparent 1px),
      linear-gradient(to bottom, var(--bone) 1px, transparent 1px);
      background-size: 8.3333% 12.5%;"
  >
  </div>
  <!-- Left readability scrim for the left-aligned headline. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: linear-gradient(to right, rgba(12,10,9,0.85), rgba(12,10,9,0.30) 45%, transparent 78%);"
  >
  </div>
  <!-- Subdue scrim: calms the background loop so the framed screenshot in front
       stays the focus, and darkens toward the bottom where the frame sits. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: linear-gradient(to bottom, rgba(12,10,9,0.30), rgba(12,10,9,0.08) 35%, rgba(12,10,9,0.78));"
  >
  </div>
  <!-- Bottom blend: ramps the whole hero to SOLID #0c0a09 at the bottom edge so
       the video dissolves seamlessly into the next section (no visible seam). -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: linear-gradient(to bottom, transparent 55%, rgba(12,10,9,0.55) 80%, #0c0a09 99%);"
  >
  </div>

  <!-- Content -->
  <div class="shell relative z-10 flex flex-col">
    <div class="lg:max-w-[70%]">
      <p
        class="hero-rise mb-8 flex items-center gap-3 text-xs uppercase tracking-[0.25em] text-muted-foreground"
        style="animation-delay: 60ms;"
      >
        <span class="h-px w-8 bg-gold/70"></span>
        The campaign, as it happens
      </p>

      <h1
        class="hero-rise font-display text-[clamp(1.85rem,6vw,6.5rem)] font-bold leading-[0.95] tracking-tight text-foreground"
        style="animation-delay: 160ms;"
      >
        <span class="block whitespace-nowrap">Command the campaign,</span>
        <span class="block whitespace-nowrap">
          by your own <span class="relative inline-block"><HeroWord client:load /></span>
        </span>
      </h1>
    </div>

    <!-- Primary actions -->
    <div
      class="hero-rise mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center lg:mt-12"
      style="animation-delay: 460ms;"
    >
      <a
        href={downloadHref}
        class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-base font-medium text-primary-foreground shadow-[0_0_40px_-10px] shadow-ember/60 transition-opacity hover:opacity-90"
      >
        <span aria-hidden="true">↓</span> Download for Mac
      </a>
      <a
        href={githubHref}
        class="text-sm text-muted-foreground underline-offset-4 transition-colors hover:text-gold hover:underline"
      >
        View on GitHub
      </a>
    </div>
    <p
      class="hero-rise mt-5 text-xs text-muted-foreground"
      style="animation-delay: 520ms;"
    >
      macOS 13+ · Apple silicon · <span class="text-gold">$39 once</span>, no
      subscription
    </p>

    <!-- Framed app screenshot — composited in front of the loop, bleeding off
         the bottom into the next section (top corners rounded, no bottom edge).
         Graceful: if the image is missing it removes itself and the empty frame
         (window chrome + dark panel) stands in until a real capture is dropped
         into public/hero/ (see README there). -->
    <div
      class="hero-rise relative z-10 mt-14 lg:mt-20"
      style="animation-delay: 600ms;"
    >
      <div
        class="relative mx-auto w-full overflow-hidden rounded-t-2xl border border-b-0 border-border bg-card p-1.5 shadow-[0_-10px_80px_-20px] shadow-ember/40 lg:rounded-t-3xl lg:p-2"
      >
        <!-- Ember corner-glow streaks (recolored from the Aceternity example). -->
        <div
          aria-hidden="true"
          class="absolute -top-px left-8 z-20 h-px w-40 bg-[radial-gradient(ellipse_at_top,var(--gold),transparent)] blur-[2px]"
        >
        </div>
        <div
          aria-hidden="true"
          class="absolute -top-px right-8 z-20 h-px w-48 bg-[radial-gradient(ellipse_at_top,var(--ember),transparent)] blur-[2px]"
        >
        </div>
        <div
          aria-hidden="true"
          class="absolute -top-10 right-10 z-10 h-24 w-64 bg-[radial-gradient(ellipse_at_top,rgba(217,119,6,0.30),transparent_70%)]"
        >
        </div>

        <!-- Inner panel -->
        <div
          class="relative aspect-[16/10] overflow-hidden rounded-t-xl bg-gradient-to-b from-card to-background lg:rounded-t-2xl"
        >
          <!-- Faux window chrome (reads as an app frame even before the capture). -->
          <div
            class="absolute inset-x-0 top-0 z-10 flex items-center gap-2 border-b border-border/60 bg-card/60 px-4 py-3 backdrop-blur"
          >
            <span class="h-2.5 w-2.5 rounded-full bg-oxblood/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-ember/80"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-gold/80"></span>
            <span class="ml-3 text-[11px] text-muted-foreground">
              conan — observing claude code
            </span>
          </div>
          <img
            src="/hero/app-screenshot.webp"
            alt="The Conan app observing a live Claude Code session — timeline, context, and usage"
            class="absolute inset-0 h-full w-full object-cover object-top"
            loading="eager"
            onerror="this.remove()"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // The video carries the `autoplay` attribute (reliable inline autoplay on
  // iOS). Here we only special-case reduced-motion (pause to the poster frame)
  // and give a belt-and-suspenders .play() nudge for engines that need it.
  const video = document.getElementById("hero-video") as HTMLVideoElement | null;
  if (video) {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      video.removeAttribute("autoplay");
      video.pause();
    } else {
      const play = () => video.play().catch(() => {});
      if (video.readyState >= 2) play();
      else video.addEventListener("loadeddata", play, { once: true });
    }
  }
</script>
