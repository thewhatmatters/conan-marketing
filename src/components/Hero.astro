---
import HeroWord from "./HeroWord.tsx";

// Primary action: the Mac download — latest GitHub Release .dmg (Apple silicon).
// "/latest/download/" always resolves to the newest release asset.
// Polar checkout (same link the app's Settings ▸ License Buy button uses).
// The price caption is the page's only buy affordance — Download stays the
// sole button; the free tier is the trial. theme=dark matches the site so
// the handoff to checkout doesn't flash white.
const buyHref =
  "https://buy.polar.sh/polar_cl_yCw19D7U1STmkUlsNrQkGRwYkeRyr196LeoYJ46vMvd?theme=dark";
const downloadHref =
  "https://github.com/thewhatmatters/conan/releases/latest/download/Conan_aarch64.dmg";
---

<section
  class="relative isolate flex min-h-screen flex-col overflow-hidden pb-20 pt-32 lg:pb-28 lg:pt-40"
>
  <!-- Background loop. `autoplay muted playsinline loop` is the canonical combo
       for reliable INLINE autoplay on iOS/Safari (a JS-only .play() is flaky
       there and blocked entirely in Low Power Mode). The script below honours
       prefers-reduced-motion by pausing to the poster frame. Poster is a real
       still from the clip, so the hero is never blank if playback is blocked.
       Sits furthest back (-z-20); the warm gradient layers tint it and keep the
       headline readable. -->
  <video
    id="hero-video"
    class="pointer-events-none absolute inset-0 -z-20 h-full w-full translate-y-16 scale-90 object-cover"
    muted
    loop
    playsinline
    preload="none"
    poster="/video/conan-battle-dark-new-keyed.jpg"
    aria-hidden="true"
  >
    <source src="/video/conan-battle-dark-new-keyed.mp4" type="video/mp4" />
  </video>

  <!-- Subdue scrim: calms the background loop so the framed screenshot in front
       stays the focus, and darkens toward the bottom where the frame sits. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: linear-gradient(to bottom, rgba(12,10,9,0.30), rgba(12,10,9,0.08) 35%, rgba(12,10,9,0.78));"
  >
  </div>
  <!-- Bottom blend: ramps the whole hero to SOLID #0c0a09 at the bottom edge so
       the video dissolves seamlessly into the next section (no visible seam). -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: linear-gradient(to bottom, transparent 55%, rgba(12,10,9,0.55) 80%, #0c0a09 99%);"
  >
  </div>
  <!-- Edge feather: an inset wash in the exact section colour so the loop's
       baked black (which can't match the CSS #0c0a09 after compression) blends
       into the page at every edge instead of reading as a faint box. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="box-shadow: inset 0 0 80px 10px #0c0a09;"
  >
  </div>

  <!-- Content -->
  <div class="shell relative z-10 flex flex-col">
    <div class="lg:max-w-[70%]">
      <p
        class="hero-rise mb-8 flex items-center gap-3 text-xs uppercase tracking-[0.25em] text-muted-foreground"
        style="animation-delay: 60ms;"
      >
        <span class="h-px w-8 bg-gold/70"></span>
        The campaign, as it happens
      </p>

      <h1
        class="hero-rise font-display text-[clamp(1.85rem,6vw,6.5rem)] font-bold leading-[0.95] tracking-tight text-foreground"
        style="animation-delay: 160ms;"
      >
        <span class="block whitespace-nowrap">Command the campaign,</span>
        <span class="block whitespace-nowrap">
          by your own <span class="relative inline-block"><HeroWord client:load /></span>
        </span>
      </h1>
    </div>

    <!-- Plain product summary — the lore headline above, landed by what Conan
         actually is. -->
    <p
      class="hero-rise mt-6 max-w-xl text-base leading-relaxed text-muted-foreground lg:text-lg"
      style="animation-delay: 360ms;"
    >
      <span class="text-foreground">Conan</span> is a native macOS app that wraps
      Claude Code in a live HUD — every prompt, tool call, skill, and token,
      surfaced as it happens.
    </p>

    <!-- Primary actions -->
    <div
      class="hero-rise mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center lg:mt-12"
      style="animation-delay: 460ms;"
    >
      <a
        href={downloadHref}
        data-dl="hero"
        class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-base font-medium text-primary-foreground shadow-[0_0_40px_-10px] shadow-ember/60 transition-opacity hover:opacity-90"
      >
        <span aria-hidden="true">↓</span> Download for Mac
      </a>
      <a
        href="#waitlist"
        class="inline-flex items-center text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        Windows or Linux? Get notified →
      </a>
    </div>
    <p
      class="hero-rise mt-5 text-xs text-muted-foreground"
      style="animation-delay: 520ms;"
    >
      macOS 13+ · Apple silicon · <a
        href={buyHref}
        data-buy="hero"
        class="text-gold underline decoration-gold/40 underline-offset-2 transition-colors hover:decoration-gold"
      >$29 once</a>, no subscription
    </p>

    <!-- Framed app loop — a fully contained window (all four corners rounded)
         composited in front of the background loop, with room beneath it before
         the next section. -->
    <div
      class="hero-rise relative z-10 mt-14 lg:mt-20"
      style="animation-delay: 600ms;"
    >
      <div
        class="relative mx-auto w-full overflow-hidden rounded-2xl border border-border bg-card p-1.5 shadow-[0_-10px_80px_-20px] shadow-ember/40 lg:rounded-3xl lg:p-2"
      >
        <!-- Ember corner-glow streaks (recolored from the Aceternity example). -->
        <div
          aria-hidden="true"
          class="absolute -top-px left-8 z-20 h-px w-40 bg-[radial-gradient(ellipse_at_top,var(--gold),transparent)] blur-[2px]"
        >
        </div>
        <div
          aria-hidden="true"
          class="absolute -top-px right-8 z-20 h-px w-48 bg-[radial-gradient(ellipse_at_top,var(--ember),transparent)] blur-[2px]"
        >
        </div>
        <div
          aria-hidden="true"
          class="absolute -top-10 right-10 z-10 h-24 w-64 bg-[radial-gradient(ellipse_at_top,rgba(217,119,6,0.30),transparent_70%)]"
        >
        </div>

        <!-- Inner panel — 16:9 to match the source clip exactly so object-cover
             fills it with NO crop (the 16:10 box was clipping the loop's sides). -->
        <div
          class="relative aspect-video overflow-hidden rounded-xl bg-gradient-to-b from-card to-background lg:rounded-2xl"
        >
          <!-- App capture loop — the clip carries its own window chrome/toolbar,
               so no faux chrome here. Same bandwidth-aware pattern as the bg loop: no
               autoplay + preload="none" so phones/reduced-motion never fetch the
               clip and the poster still stands in. Panel is 16:9 to match the
               source exactly, so object-cover fills it with no crop. -->
          <video
            id="hero-frame-video"
            class="absolute inset-0 h-full w-full rounded-xl object-cover object-top lg:rounded-2xl"
            muted
            loop
            playsinline
            preload="none"
            poster="/video/conan-hero.jpg"
            aria-label="The Conan app observing a live Claude Code session — timeline, context, and usage"
          >
            <!-- H.264 mp4 only. A VP9 webm was dropped: on some Mac GPUs Chrome
                 hardware-decodes VP9 to BLACK frames while still reporting
                 "playing" (currentTime advances), so the loop looked broken in
                 prod. H.264 has none of that — same proven codec as the bg loop. -->
            <source src="/video/conan-hero.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // The loop plays ONLY on larger screens with motion allowed. With no
  // `autoplay` attribute and `preload="none"`, the .mp4 is never fetched until
  // we call .play() — so on phones (and reduced-motion) nothing downloads and
  // the poster .jpg stands in (saves ~1.3MB of mobile bandwidth). On desktop we
  // bump preload and play; a JS .play() of a muted/playsinline video is allowed
  // without a gesture there.
  const videos = [
    document.getElementById("hero-video"),
    document.getElementById("hero-frame-video"),
  ].filter(Boolean) as HTMLVideoElement[];
  const allow =
    !matchMedia("(prefers-reduced-motion: reduce)").matches &&
    matchMedia("(min-width: 768px)").matches;
  if (allow) {
    for (const video of videos) {
      video.preload = "auto";
      video.play().catch(() => {});
    }
  }
  // else: leave the poster frames; the videos are never loaded.
</script>
