---
import FaqAccordion from "./FaqAccordion.tsx";
import { faqs } from "../data/faqs.ts";
---

<section id="faq" class="faq relative py-24 lg:py-32">
  <div class="shell grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12">
    <!-- Intro column -->
    <div class="faq-col relative isolate lg:col-span-5" style="--d: 0ms">
      <p
        class="relative z-10 mb-4 flex items-center gap-3 text-xs uppercase tracking-[0.25em] text-muted-foreground"
      >
        <span class="h-px w-8 bg-gold/70"></span>
        Frequently asked
      </p>
      <h2
        class="relative z-10 font-display text-[clamp(1.75rem,4vw,3.25rem)] font-bold leading-[0.98] tracking-tight text-foreground"
      >
        Answers before you ride out.
      </h2>
      <p class="relative z-10 mt-5 max-w-sm text-sm leading-relaxed text-muted-foreground">
        Still wondering something? <a
          href="mailto:hello@conan.sh"
          class="text-gold underline-offset-4 transition-colors hover:underline"
          >Email us</a
        >.
      </p>

      <!-- Lore beat: the rider. Cross-browser transparent video is unreliable
           (Safari's HEVC-alpha wouldn't encode — flattens to black; VP9 webm
           alpha is Chrome/FF-only), so we use ONE universal opaque clip keyed
           onto #0c0a09 and feather its edges into the section so the rectangle
           dissolves. Looks identical to a cut-out on this dark section and
           plays everywhere. autoplay + muted + playsinline + loop = inline. -->
      <div class="relative z-0 -mt-4 w-full max-w-[480px] lg:-mt-8">
        <video
          id="faq-video"
          class="block aspect-square w-full object-contain"
          muted
          loop
          playsinline
          preload="none"
          poster="/video/conan-horse.png"
          aria-hidden="true"
        >
          <source src="/video/conan-horse.mp4" type="video/mp4" />
        </video>
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0"
          style="box-shadow: inset 0 0 26px 16px #0c0a09;"
        >
        </div>
        <!-- Bottom fade: ramps to the background colour so the horse's hooves
             dissolve into the page rather than ending on a hard edge. -->
        <div
          aria-hidden="true"
          class="pointer-events-none absolute inset-0"
          style="background: linear-gradient(to bottom, transparent 46%, rgba(12,10,9,0.55) 70%, #0c0a09 93%);"
        >
        </div>
      </div>
    </div>

    <!-- Accordion column -->
    <div class="faq-col lg:col-span-7 lg:col-start-6" style="--d: 120ms">
      <FaqAccordion items={faqs} client:visible />
    </div>
  </div>
</section>

<script>
  // The rider loop plays ONLY on larger screens with motion allowed. With no
  // `autoplay` and `preload="none"`, the .mp4 is never fetched on phones (or
  // under reduced-motion) — the poster (conan-horse.png) stands in.
  const faqVideo = document.getElementById("faq-video") as HTMLVideoElement | null;
  if (faqVideo) {
    const allow =
      !matchMedia("(prefers-reduced-motion: reduce)").matches &&
      matchMedia("(min-width: 768px)").matches;
    if (allow) {
      faqVideo.preload = "auto";
      faqVideo.play().catch(() => {});
    }
  }

  const faq = document.querySelector(".faq");
  if (faq) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-in");
            obs.unobserve(e.target);
          }
        }
      },
      { threshold: 0.15 },
    );
    io.observe(faq);
  }
</script>
