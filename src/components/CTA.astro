---
import WaitlistForm from "./WaitlistForm.tsx";

// Final CTA band — fire-glow reprise before the footer. Primary action is the
// Mac download; a general Conan news/updates signup sits beneath (folds in the
// Windows/Linux availability ask — capture the email, never a greyed-out button).
// Each signup is stored in KV + forwarded to hello@conan.sh (see /api/waitlist).
// TODO: point downloadHref at the latest release .dmg once published.
const downloadHref = "#download";
---

<section
  id="download"
  class="cta relative isolate overflow-hidden pb-28 pt-10 lg:pb-36 lg:pt-12"
>
  <!-- The nav/footer "Pricing" links here: we sell one app + a $39 unlock, not
       tiers, so there's no pricing table — this band carries the price. Anchor
       sits at the band top with scroll-margin so the sticky header clears it. -->
  <span id="pricing" aria-hidden="true" class="absolute top-0 scroll-mt-28"></span>

  <!-- No fire glow here: the CTA text sits on clean ground. The section's single
       warm accent now lives in the footer, behind the barbarian, so the CTA and
       footer read as one continuous section. -->

  <div class="shell flex flex-col items-center text-center">
    <p
      class="cta-col mb-4 text-xs uppercase tracking-[0.25em] text-gold"
      style="--d: 0ms"
    >
      Miss nothing.
    </p>
    <h2
      class="cta-col font-display text-[clamp(2rem,5vw,4rem)] font-bold leading-[0.98] tracking-tight text-foreground"
      style="--d: 60ms"
    >
      Take up the steel.
    </h2>

    <!-- Primary action -->
    <div
      class="cta-col mt-9 flex flex-col items-center gap-4 sm:flex-row"
      style="--d: 160ms"
    >
      <a
        href={downloadHref}
        class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-base font-medium text-primary-foreground shadow-[0_0_40px_-10px] shadow-ember/60 transition-opacity hover:opacity-90"
      >
        <span aria-hidden="true">↓</span> Download for Mac
      </a>
    </div>
    <p
      class="cta-col mt-5 text-xs text-muted-foreground"
      style="--d: 220ms"
    >
      <span class="text-gold">Premium $39, once</span> · lifetime 1.x · macOS 13+
      (Apple silicon)
    </p>

    <!-- Conan news/updates signup. `id="waitlist"` is the nav "Get notified"
         target; scroll-mt clears the sticky header on jump + scroll-spy. -->
    <div
      id="waitlist"
      class="cta-col mt-14 flex w-full max-w-md scroll-mt-28 flex-col items-center gap-4 border-t border-border/40 pt-10"
      style="--d: 300ms"
    >
      <p class="text-sm leading-relaxed text-muted-foreground">
        <span class="font-medium text-gold">Dispatches from the forge.</span>
        New features, releases, and Windows/Linux availability — sent only when
        there's something worth your steel.
      </p>
      <WaitlistForm client:visible />
      <p class="text-xs text-muted-foreground/70">
        Occasional Conan news. Unsubscribe anytime.
      </p>
    </div>
  </div>
</section>

<script>
  const cta = document.querySelector(".cta");
  if (cta) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-in");
            obs.unobserve(e.target);
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(cta);
  }
</script>
