---
import WaitlistForm from "./WaitlistForm.tsx";

// Final CTA band — fire-glow reprise before the footer. Primary action is the
// Mac download (latest GitHub Release .dmg, Apple silicon); the waitlist signup
// below captures Windows/Linux interest + general news.
// Each signup is stored in KV + forwarded to hello@conan.sh (see /api/waitlist).
const downloadHref =
  "https://github.com/thewhatmatters/conan/releases/latest/download/Conan_aarch64.dmg";
// Polar checkout — the clickable price under the Download button (see Hero).
// No theme override (see Hero.astro).
const buyHref =
  "https://buy.polar.sh/polar_cl_yCw19D7U1STmkUlsNrQkGRwYkeRyr196LeoYJ46vMvd";
---

<section
  id="download"
  class="cta relative isolate overflow-hidden pb-28 pt-10 lg:pb-36 lg:pt-12"
>
  <!-- The nav/footer "Pricing" links here: we sell one app + a $29 unlock, not
       tiers, so there's no pricing table — this band carries the price. Anchor
       sits at the band top with scroll-margin so the sticky header clears it. -->
  <span id="pricing" aria-hidden="true" class="absolute top-0 scroll-mt-28"></span>

  <!-- No fire glow here: the CTA text sits on clean ground. The section's single
       warm accent now lives in the footer, behind the barbarian, so the CTA and
       footer read as one continuous section. -->

  <div class="shell flex flex-col items-center text-center">
    <p
      class="cta-col mb-4 text-xs uppercase tracking-[0.25em] text-gold"
      style="--d: 0ms"
    >
      Miss nothing.
    </p>
    <h2
      class="cta-col font-display text-[clamp(2rem,5vw,4rem)] font-bold leading-[0.98] tracking-tight text-foreground"
      style="--d: 60ms"
    >
      Take up the steel.
    </h2>

    <!-- Primary action: the Mac download. The waitlist below it stays for
         Windows/Linux + general news. -->
    <a
      href={downloadHref}
      data-dl="cta"
      class="cta-col mt-9 inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-base font-medium text-primary-foreground shadow-[0_0_40px_-10px] shadow-ember/60 transition-opacity hover:opacity-90"
      style="--d: 140ms"
    >
      <span aria-hidden="true">↓</span> Download for Mac
    </a>
    <p
      class="cta-col mt-5 text-xs text-muted-foreground"
      style="--d: 200ms"
    >
      Free to download · <a
        href={buyHref}
        data-buy="cta"
        class="text-gold underline decoration-gold/40 underline-offset-2 transition-colors hover:decoration-gold"
      >Premium $29, once</a> ·
      lifetime 1.x · macOS 13+ (Apple silicon)
    </p>

    <!-- Product Hunt launch badge — LAUNCH DAY ONLY (see Hero.astro). -->
    <a
      href="https://www.producthunt.com/products/conan?embed=true&utm_source=badge-featured&utm_medium=badge&utm_campaign=badge-conan"
      target="_blank"
      rel="noopener noreferrer"
      data-ph="cta"
      class="cta-col mt-6 inline-block transition-opacity hover:opacity-90"
      style="--d: 260ms"
    >
      <img
        alt="Conan - A native Mac cockpit for Claude Code | Product Hunt"
        width="250"
        height="54"
        loading="lazy"
        src="https://api.producthunt.com/widgets/embed-image/v1/featured.svg?post_id=1165939&theme=dark&t=1781314868168"
      />
    </a>

    <!-- Conan news/updates signup. `id="waitlist"` is the nav "Get notified"
         target; scroll-mt clears the sticky header on jump + scroll-spy. -->
    <div
      id="waitlist"
      class="cta-col mt-14 flex w-full max-w-md scroll-mt-28 flex-col items-center gap-4 border-t border-border/40 pt-10"
      style="--d: 300ms"
    >
      <p class="text-sm leading-relaxed text-muted-foreground">
        <span class="font-medium text-gold">Dispatches from the forge.</span>
        New features, releases, and Windows/Linux availability — sent only when
        there's something worth your steel.
      </p>
      <WaitlistForm client:visible />
      <p class="text-xs text-muted-foreground/70">
        Occasional Conan news. Unsubscribe anytime.
      </p>
    </div>
  </div>
</section>

<script>
  const cta = document.querySelector(".cta");
  if (cta) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-in");
            obs.unobserve(e.target);
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(cta);
  }
</script>
