---
import WaitlistForm from "./WaitlistForm.tsx";

// Final CTA band — fire-glow reprise before the footer. Primary action is the
// Mac download; the Windows/Linux waitlist sits beneath as the platform line
// (story doc §2 — capture the email, never a greyed-out "Windows" button).
// TODO: point downloadHref at the latest GitHub Release .dmg once published.
const downloadHref = "#download";
const githubHref = "https://github.com/";
---

<section
  id="download"
  class="cta relative isolate overflow-hidden border-t border-border/60 py-28 lg:py-36"
>
  <!-- Fire glow reprise: oxblood→ember rising from the base, echoing the hero. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background:
      radial-gradient(60% 55% at 50% 118%, rgba(127,29,29,0.55), rgba(217,119,6,0.18) 40%, transparent 74%);"
  >
  </div>
  <!-- Edge vignette. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(120% 90% at 50% 50%, transparent 55%, rgba(0,0,0,0.55) 100%);"
  >
  </div>

  <div class="shell flex flex-col items-center text-center">
    <p
      class="cta-col mb-4 font-mono text-xs uppercase tracking-[0.25em] text-gold"
      style="--d: 0ms"
    >
      Miss nothing.
    </p>
    <h2
      class="cta-col font-display text-[clamp(2rem,5vw,4rem)] font-bold leading-[0.98] tracking-tight text-foreground"
      style="--d: 60ms"
    >
      Take up the steel.
    </h2>

    <!-- Primary action -->
    <div
      class="cta-col mt-9 flex flex-col items-center gap-4 sm:flex-row"
      style="--d: 160ms"
    >
      <a
        href={downloadHref}
        class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-base font-medium text-primary-foreground shadow-[0_0_40px_-10px] shadow-ember/60 transition-opacity hover:opacity-90"
      >
        <span aria-hidden="true">↓</span> Download for Mac
      </a>
      <a
        href={githubHref}
        class="text-sm text-muted-foreground underline-offset-4 transition-colors hover:text-gold hover:underline"
      >
        View on GitHub
      </a>
    </div>
    <p
      class="cta-col mt-5 font-mono text-xs text-muted-foreground"
      style="--d: 220ms"
    >
      Free to wield · <span class="text-gold">Premium $39, once</span> · macOS 13+
      (Apple silicon)
    </p>

    <!-- Platform handling / waitlist -->
    <div
      class="cta-col mt-14 flex w-full max-w-md flex-col items-center gap-4 border-t border-border/40 pt-10"
      style="--d: 300ms"
    >
      <p class="text-sm leading-relaxed text-muted-foreground">
        The Hyborian age comes first to Mac. On Windows or Linux?
      </p>
      <WaitlistForm client:visible />
    </div>
  </div>
</section>

<script>
  const cta = document.querySelector(".cta");
  if (cta) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("is-in");
            obs.unobserve(e.target);
          }
        }
      },
      { threshold: 0.2 },
    );
    io.observe(cta);
  }
</script>
